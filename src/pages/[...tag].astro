---
import type { GetStaticPaths } from 'astro';
import Main from '@/components/layouts/Main.astro';
import { tagCollection } from '@/utils/tags';
import { taggedArticles } from '@/utils/articles';

export const getStaticPaths = (async () => {
  return tagCollection().map(({ tag }) => {
    const articles = taggedArticles(tag);

    return {
      params: { tag },
      props: { articles, tag },
    };
  });
}) satisfies GetStaticPaths;

const { tag } = Astro.props;
---

<Main title={`Tag: ${tag}`} />

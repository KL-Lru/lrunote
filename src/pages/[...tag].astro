---
import type { GetStaticPaths } from 'astro';
import Main from '@/components/layouts/Main.astro';
import { tagCollection, tagToUrl } from '@/utils/tags';
import { taggedArticles } from '@/utils/articles';

export const getStaticPaths = (async () => {
  return tagCollection()
    .map(({ tag, label }) => {
      const articles = taggedArticles(tag);
      const urlPath = tagToUrl(tag);

      // 空文字列（topタグ）の場合はスキップ（index.mdxで処理）
      if (urlPath === '') {
        return null;
      }

      return {
        params: { tag: urlPath },
        props: { articles, tag, label },
      };
    })
    .filter((path) => path !== null);
}) satisfies GetStaticPaths;

const { label, tag } = Astro.props;
---

<Main title={`Tag: ${label}`} currentTag={tag} />

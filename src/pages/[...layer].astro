---
import type { GetStaticPaths } from "astro";
import Layer from "@/components/layouts/Layer.astro";
import { layerCollection } from "@/utils/layers";
import { layerTree } from "@/utils/tree";

export const getStaticPaths = (async () => {
  const layers = await layerCollection();

  // ルートレイヤー（slug 空）は index.astro が担当するため除外する
  return layers
    .filter((layer) => !!layer.slug)
    .map((layer) => ({
      params: { layer: layer.slug },
      props: { layerId: layer.id },
    }));
}) satisfies GetStaticPaths;

const node = await layerTree(Astro.props.layerId);
if (!node) {
  throw new Error(`Layer not found: ${Astro.props.layerId}`);
}
---

<Layer node={node} />

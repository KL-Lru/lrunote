---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import Main from '@/components/layouts/Main.astro';
import { articleCollection } from '@/utils/articles';
import { parent } from '@/utils/paths';

export const getStaticPaths = (async () => {
  const collection = await articleCollection();

  return collection.map((article) => ({
    params: { permalink: article.data.permalink },
    props: { entry: article },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
const categoryPath = parent(entry.id);
---

<Main title={entry.data.title} currentTag={categoryPath}>
  <Content />
</Main>

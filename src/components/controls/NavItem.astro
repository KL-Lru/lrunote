---
import { Icon } from 'astro-icon/components';
import styles from './NavItem.module.css';

interface Props {
  href: string;
  label: string;
  targetPath?: string;
  buttonPosition?: 'left' | 'right';
  isActive?: boolean;
}

const {
  href,
  label,
  targetPath,
  buttonPosition,
  isActive = false,
} = Astro.props;

const ICON_SIZE = 28;
---

<div class={styles.navContainer}>
  {
    buttonPosition === 'left' && (
      <button
        type="button"
        class={styles.navButton}
        data-target-path={targetPath}
      >
        <Icon name={'mdi:menu-left'} size={ICON_SIZE} />
      </button>
    )
  }

  <a href={href} class:list={[styles.navLink, { [styles.active]: isActive }]}>
    {label}
  </a>

  {
    buttonPosition === 'right' && (
      <button
        type="button"
        class={styles.navButton}
        data-target-path={targetPath}
      >
        <Icon name={'mdi:menu-right'} size={ICON_SIZE} />
      </button>
    )
  }
</div>

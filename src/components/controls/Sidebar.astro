---
import { clean } from '@/utils/paths';
import { siteTree } from '@/utils/tree';
import SidebarNode from './SidebarNode.astro';

const currentPath = clean(Astro.url.pathname);
const tree = await siteTree();
---

<aside id="sidebar" class="sidebar" data-current={currentPath}>
  <div class="sidebar-title">Index</div>
  <nav class="tree">
    {tree.children.map((node) => <SidebarNode node={node} currentPath={currentPath} />)}
  </nav>
</aside>


<style>
  .sidebar {
    height: 100%;
    width: var(--sidebar-width);

    color: var(--text-color);
    background-color: var(--control-background-color);
    border-right: 1px solid var(--border-color);

    overflow-y: auto;
    overflow-x: hidden;
    padding: 1rem 0.625rem 2.5rem;
  }

  .sidebar-title {
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 0.25rem 0.625rem 0.625rem;
  }

  .tree {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  @media (width < 1024px) {
    .sidebar {
      position: absolute;
      top: 0;
      bottom: 0;
      left: -100%;
      height: 100%;
      z-index: var(--control-z);

      transition: left 0.2s ease-out;
    }

    .sidebar[data-active='true'] {
      left: 0;
    }
  }
</style>

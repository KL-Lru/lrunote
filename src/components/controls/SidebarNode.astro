---
import { Icon } from 'astro-icon/components';
import type { TreeNode } from '@/utils/tree';

interface Props {
  node: TreeNode;
  currentPath: string;
}

const { node, currentPath } = Astro.props;

const ICON_SIZE = 15;
const isActive = currentPath === node.id;
// 現在地を含むレイヤーは初期状態で開く
const isOpen =
  node.type === 'layer' &&
  (currentPath === node.id || currentPath.startsWith(node.id + '/'));
---

{
  node.type === 'article' ? (
    <a class:list={['tree-node', { active: isActive }]} href={node.id}>
      <span class="node-caret" aria-hidden="true" />
      <span class="node-icon">
        <Icon name="mdi:file-document-outline" size={ICON_SIZE} />
      </span>
      <span class="node-label">{node.title}</span>
    </a>
  ) : (
    <div class="folder-node" data-layer-id={node.id} data-open={String(isOpen)}>
      <div class:list={['tree-node', { active: isActive }]}>
        {node.children.length > 0 ? (
          <button type="button" class="node-caret" data-toggle aria-label="開閉">
            <Icon name="mdi:chevron-right" size={12} />
          </button>
        ) : (
          <span class="node-caret" aria-hidden="true" />
        )}
        <a class="node-link" href={node.id}>
          <span class="node-icon">
            <Icon name="mdi:folder-outline" class="ico-closed" size={ICON_SIZE} />
            <Icon name="mdi:folder-open-outline" class="ico-open" size={ICON_SIZE} />
          </span>
          <span class="node-label">{node.title}</span>
        </a>
      </div>

      {node.children.length > 0 && (
        <div class="subtree-wrap">
          <div class="subtree">
            {node.children.map((child) => (
              <Astro.self node={child} currentPath={currentPath} />
            ))}
          </div>
        </div>
      )}
    </div>
  )
}

<style>
  .tree-node {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    width: 100%;

    color: var(--text-color);
    font-size: 0.85rem;
    text-decoration: none;

    padding: 0.3rem 0.5rem;
    border-radius: 6px;

    transition: background-color 0.1s ease;
  }

  .tree-node:hover {
    background-color: var(--accent-soft);
    text-decoration: none;
  }

  .tree-node.active {
    background-color: var(--accent-soft);
    font-weight: 700;
  }

  .node-caret {
    width: 1rem;
    height: 1rem;

    display: grid;
    place-items: center;

    color: var(--text-muted);
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;

    transition: transform 0.15s ease;
  }

  .folder-node[data-open='true'] > .tree-node .node-caret {
    transform: rotate(90deg);
  }

  .node-link {
    flex: 1;
    min-width: 0;

    display: flex;
    align-items: center;
    gap: 0.375rem;

    color: inherit;
    text-decoration: none;
  }

  .node-icon {
    width: 1rem;
    height: 1rem;

    display: grid;
    place-items: center;
    color: var(--text-muted);
  }

  .tree-node.active .node-icon {
    color: var(--accent-color);
  }

  .node-icon .ico-open {
    display: none;
  }

  .folder-node[data-open='true'] > .tree-node .node-icon .ico-open {
    display: block;
  }

  .folder-node[data-open='true'] > .tree-node .node-icon .ico-closed {
    display: none;
  }

  .node-label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .subtree-wrap {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: grid-template-rows 0.2s ease;
  }

  .folder-node[data-open='true'] > .subtree-wrap {
    grid-template-rows: 1fr;
  }

  .subtree {
    min-height: 0;

    margin-left: 0.7rem;
    padding-left: 0.25rem;
    border-left: 1px solid var(--border-color);

    display: flex;
    flex-direction: column;
    gap: 1px;
  }
</style>

---
import Search from "astro-pagefind/components/Search";
---

<div id="search-modal" class="searchModal">
  <div class="modalContent">
    <Search
      id="pagefind-search"
      className="pagefind-ui"
      uiOptions={{
        showSubResults: true,
        excerptLength: 100,
      }}
    />
  </div>
</div>

<script>
  import { deactivate } from '@/utils/activate';

  const modalElement = document.getElementById('search-modal');
  const overlayElement = document.getElementById('overlay');

  function closeModal() {
    if (modalElement?.dataset.active !== 'true') {
      return;
    }
    deactivate('search-modal');
    deactivate('overlay');
  }

  if (overlayElement) {
    overlayElement.addEventListener('click', closeModal);
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeModal();
    }
  });
</script>

<style>
  .searchModal {
    position: fixed;
    z-index: calc(var(--overlay-z) + 10);

    top: 0;
    left: 0;
    right: 0;
    bottom: 0;

    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10vh;

    pointer-events: none;

    opacity: 0;
    visibility: hidden;

    transition:
      opacity 0.2s ease-out,
      visibility 0.2s ease-out;
  }

  .searchModal[data-active="true"] {
    opacity: 1;
    visibility: visible;
  }

  .modalContent {
    pointer-events: auto;
    width: 90%;
    max-width: 1024px;
    max-height: 70vh;
    overflow-y: auto;

    background-color: var(--control-background-color);
    border-radius: 8px;
  }

  /* Pagefind UI style overrides */
  .searchModal :global(.pagefind-ui) {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--link-color);
    --pagefind-ui-text: var(--text-color);
    --pagefind-ui-background: var(--control-background-color);
    --pagefind-ui-border: var(--border-color);
    --pagefind-ui-tag: var(--accent-color);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: var(--font-sans);
  }

  .searchModal :global(.pagefind-ui__search-input) {
    color: var(--text-color);
    background-color: var(--background-color);
  }
  .searchModal :global(.pagefind-ui__search-input):focus-visible {
    outline: none;
    box-shadow: none;
  }
  /* Clear button - replace text with X icon */
  .searchModal :global(.pagefind-ui__search-clear) {
    color: var(--text-color);
    font-size: 0;
    border-radius: 0;
    padding: 0.5rem;
  }
  .searchModal :global(.pagefind-ui__search-clear)::before {
    content: "✕";
    font-size: 1.2rem;
    color: var(--text-color);
  }

  /* Search form and results container */
  .searchModal :global(.pagefind-ui__form) {
  }

  .searchModal :global(.pagefind-ui__message) {
    color: var(--text-color);
    padding: 0 1rem 1rem;
  }

  .searchModal :global(.pagefind-ui__results) {
    padding: 0 1rem 1rem;
  }

  .searchModal :global(.pagefind-ui__result) {
    padding: 0 2rem 1rem;
  }

  .searchModal :global(.pagefind-ui__result-thumb) {
    display: none;
  }

  .searchModal :global(.pagefind-ui__result-link) {
    color: var(--link-color);
  }

  .searchModal :global(.pagefind-ui__result-excerpt) {
    color: var(--text-color);
  }

  .searchModal :global(.pagefind-ui__result-inner) {
    margin-left: 0;
  }
</style>

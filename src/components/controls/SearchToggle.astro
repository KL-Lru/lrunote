---
import { Icon } from "astro-icon/components";
---

<button id="search-toggle" class="toggleButton">
  <div class="buttonIcon">
    <Icon name="mdi:magnify" />
  </div>
</button>

<script>
  import { activate } from '@/utils/activate';

  const toggleElement = document.getElementById('search-toggle');

  if (toggleElement) {
    toggleElement.addEventListener('click', () => {
      activate('overlay');
      activate('search-modal');
    });
  }
</script>

<style>
  .toggleButton {
    cursor: pointer;
    font-size: 1.5rem;

    display: flex;
    align-items: center;
    justify-content: center;

    color: var(--text-color);
    background-color: var(--control-background-color);

    border: none;
    border-radius: 5px;
    padding: 0.3rem 0.5rem;

    transition:
      color 0.2s ease-in-out,
      background-color 0.2s ease-in-out;

    &:hover {
      color: var(--invert-text-color);
      background-color: var(--invert-background-color);
    }
  }

  .buttonIcon {
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>

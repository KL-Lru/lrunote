---
import { Icon } from "astro-icon/components";
---

<button id="theme-toggle" class={"toggleButton"}>
  <div class={"iconLight"}>
    <Icon name="mdi:weather-sunny" />
  </div>
  <div class={"iconDark"}>
    <Icon name="mdi:moon-and-stars" />
  </div>
</button>

<script>
  import { getTheme, setTheme } from '@/utils/theme';

  const toggleElement = document.querySelector('#theme-toggle');

  if (toggleElement) {
    toggleElement.addEventListener('click', () => {
      const html = document.documentElement;

      if (html.classList.contains('switch')) {
        return;
      }

      html.classList.add('switch');

      if (getTheme() === 'dark') {
        setTheme('light');
      } else {
        setTheme('dark');
      }

      const handleTransitionEnd = () => {
        html.classList.remove('switch');
        html.removeEventListener('transitionend', handleTransitionEnd);
      };

      html.addEventListener('transitionend', handleTransitionEnd);
    });
  }
</script>

<style>
  .toggleButton {
    cursor: pointer;
    font-size: 1.5rem;

    display: flex;
    align-items: center;
    justify-content: center;

    color: var(--text-color);
    background-color: var(--control-background-color);

    border: none;
    border-radius: 5px;
    padding: 0.3rem 0.5rem;

    transition:
      color 0.2s ease,
      background-color 0.2s ease;

    &:hover {
      color: var(--invert-text-color);
      background-color: var(--invert-background-color);
    }
  }

  .iconLight,
  .iconDark {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  html:global(.light) .iconLight,
  html:global(.dark) .iconDark {
    display: none;
  }
</style>

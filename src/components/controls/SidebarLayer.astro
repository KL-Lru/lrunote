---
import SidebarItem from './SidebarItem.astro';
import type { WrappedLayer } from '@/utils/layers';
import { parentLayer, findLayer, resolveLayer } from '@/utils/layers';
import { clean } from '@/utils/paths';

type Props = {
  layer: WrappedLayer;
};

const currentPath = clean(Astro.url.pathname);
const currentLayerPath = await findLayer(currentPath);

const layer_id = Astro.props.layer.id
const parent = await parentLayer(layer_id);
const layer = await resolveLayer(Astro.props.layer);
const sections = layer.sections;
---

<div
  class={'sidebarLayer'}
  data-path={layer_id}
  data-active={currentLayerPath === layer_id}
>
  <h2 class={'sidebarTitle'}>
    <a href={layer_id}>{layer.title}</a>
  </h2>

  <div class={'divider'}></div>

  {parent && <SidebarItem content={parent} variant="left" />}

  {
    sections.length > 0 &&
      sections.map((section) => (
        <section class={'sidebarSection'}>
          <h3>{section.title}</h3>
          <ul class={'sidebarContents'}>
            {section.items.map((content) => (
              <SidebarItem
                content={content}
                variant={content.collection === 'layers' ? 'right' : undefined}
              />
            ))}
          </ul>
        </section>
      ))
  }
</div>

<style>
  .sidebarLayer {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    right: 0;

    display: flex;
    flex-direction: column;
    gap: 1rem;

    opacity: 0;
    visibility: hidden;
    pointer-events: none;

    transition:
      opacity 0.2s ease-out,
      visibility 0.2s ease-out;

    &[data-active='true'] {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    &[data-active='true'][data-slide-direction='left'] {
      animation: slideInFromRight 0.2s ease-out;
    }

    &[data-active='true'][data-slide-direction='right'] {
      animation: slideInFromLeft 0.2s ease-out;
    }
  }

  .divider {
    width: 100%;
    height: 1px;
    background-color: var(--border-color);
  }

  .sidebarTitle {
    font-size: 1.2rem;

    a {
      color: inherit;
      text-decoration: none;
    }
  }

  .sidebarSection {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sidebarSection h3 {
    font-size: 1rem;
    margin: 0 0 0.5rem 0;
    color: var(--text-color);
  }

  .sidebarContents {
    display: flex;
    flex-direction: column;
    align-items: stretch;

    list-style: none;
    margin: 0;
    padding: 0;

    gap: 0.2rem;
  }
</style>

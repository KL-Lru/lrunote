---
import type { TocItem } from "@/utils/toc";

interface Props {
  title: string;
  items: TocItem[];
}

const { title, items } = Astro.props;
---

{
  items.length > 1 && (
    <nav class="toc" aria-label={title}>
      <div class="toc-title">{title}</div>
      {items.map((item) => (
        <a
          href={`#${item.targetId}`}
          data-toc-link={item.targetId}
          style={`--toc-depth:${item.depth - 1}`}
        >
          {item.label}
        </a>
      ))}
    </nav>
  )
}

<script>
  import { initToc, currentTocLinks } from '@/utils/toc';

  initToc();

  function scrollToContent(tocLink: string | undefined) {
    if (!tocLink) return;

    const target = document.getElementById(tocLink);
    if (!target) return;

    // 折りたたみ可能なターゲット（レイヤーのセクション）は開いてからスクロールする
    if (target.hasAttribute('data-open')) {
      target.dataset.open = 'true';
      target
        .querySelector('[data-folder-toggle]')
        ?.setAttribute('aria-expanded', 'true');
    }

    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  const links = currentTocLinks();
  links.forEach((link) => {
    link.addEventListener('click', (event) => {
      event.preventDefault();
      scrollToContent(link.dataset.tocLink);
    });
  });
</script>

<style>
  .toc {
    position: sticky;
    top: 2.4rem;
    width: 210px;
    max-width: var(--sidebar-width);
    max-height: calc(100vh - 5rem);
    overflow-y: auto;

    font-size: 0.75rem;
  }

  .toc-title {
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .toc a {
    display: block;
    color: var(--text-muted);
    padding: 0.25rem 0 0.25rem calc(0.75rem + var(--toc-depth, 0) * 0.75rem);
    border-left: 2px solid var(--border-color);
    text-decoration: none;

    transition:
      color 0.1s ease,
      border-color 0.1s ease;
  }

  .toc a:hover {
    color: var(--text-color);
  }

  .toc a.active {
    color: var(--accent-color);
    border-left-color: var(--accent-color);
    font-weight: 600;
  }

  @media (width < 1024px) {
    .toc {
      display: none;
    }
  }
</style>

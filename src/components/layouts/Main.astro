---
import TopBar from '@/components/controls/TopBar.astro';
import Sidebar from '@/components/controls/Sidebar.astro';
import Content from '@/components/layouts/Content.astro';

import initialize from '@/assets/scripts/init?inline-bundle';
import '@/assets/styles/globals.css';

const props = Astro.props.frontmatter || Astro.props;
const { title } = props;
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script is:inline set:html={initialize} />
  </head>
  <body>
    <main class="container">
      <div class="topBarContainer">
        <TopBar />
      </div>
      <div class="sideBarContainer">
        <Sidebar />
      </div>
      <div class="mainContent">
        <Content>
          <slot />
        </Content>
      </div>
      <div id="overlay"></div>
    </main>
  </body>
</html>

<style>
  .container {
    display: grid;
    position: relative;
    height: 100vh;
    width: 100vw;

    grid-template-areas:
      'topbar topbar'
      'sidebar main';
    grid-template-columns: min-content 1fr;
    grid-template-rows: min-content 1fr;
  }

  .topBarContainer {
    grid-area: topbar;
  }

  .sideBarContainer {
    grid-area: sidebar;
  }

  .mainContent {
    grid-area: main;
  }

  #overlay {
    position: fixed;
    z-index: var(--overlay-z);
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.2s ease-out,
      visibility 0.2s ease-out;
  }
  #overlay.active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  @media (width < 1024px) {
    .container {
      grid-template-areas:
        'topbar'
        'main';
      grid-template-columns: 1fr;
      grid-template-rows: min-content 1fr;
    }
  }
</style>
